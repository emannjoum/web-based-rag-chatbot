# MongoDB
MONGODB_URI=mongodb://localhost:27017

# LLM providers
OPENAI_API_KEY=
GEMINI_API_KEY=

# Search providers
SERPER_API_KEY=
TAVILY_API_KEY=
DEFAULT_SEARCH_METHOD=Serper

# API server
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000

# Frontend build path (used when API serves the React bundle)
FRONTEND_DIST_PATH=frontend/dist

# Redis cache (recent chat histories)
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_ENABLED=true
REDIS_CACHE_TTL_SECONDS=300

# MySQL (user accounts)
MYSQL_URL=mysql+pymysql://medatlas:medatlas@localhost:3306/medatlas

# Auth
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
